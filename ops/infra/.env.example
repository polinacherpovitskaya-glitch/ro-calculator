# Copy to .env on the VPS and fill in real values.
# DO NOT commit the real .env.

DOMAIN=ops-staging.recycleobject.ru

POSTGRES_USER=ops
POSTGRES_PASSWORD=<generate with: openssl rand -hex 32>
POSTGRES_DB=ops

# Filled in Task 9 (Object Storage):
S3_ENDPOINT=https://s3.ru-3.storage.selcloud.ru
S3_REGION=ru-3
S3_BUCKET=ro-ops-backups
S3_BUCKET_PRODUCT_IMAGES=ro-ops-product-images
S3_BUCKET_MOLD_PHOTOS=ro-ops-mold-photos
# Optional if product-images bucket is created in a different Selectel region than S3_ENDPOINT:
S3_ENDPOINT_PRODUCT_IMAGES=
S3_REGION_PRODUCT_IMAGES=
# Optional if mold-photos bucket is created in a different Selectel region than S3_ENDPOINT:
S3_ENDPOINT_MOLD_PHOTOS=
S3_REGION_MOLD_PHOTOS=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Telegram task bot (Block 12):
# OPS_BOT_TOKEN must also be inserted into bot_tokens with role='admin'
# so the bot can manage Telegram bindings and read notification events.
TG_BOT_TOKEN=
OPS_BOT_TOKEN=<generate with: openssl rand -hex 32>
TASK_BOT_POLL_INTERVAL_MS=15000
TELEGRAM_PROXY_URL=
TELEGRAM_REQUEST_FAMILY=4
TELEGRAM_REQUEST_TIMEOUT_MS=45000
